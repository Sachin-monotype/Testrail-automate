# TestRail API — copy to .env and fill in values.
# https://www.gurock.com/testrail/docs/user-guide/howto/api/

TESTRAIL_URL=https://type.testrail.com
TESTRAIL_USERNAME=your.email@company.com
TESTRAIL_PASSWORD=
TESTRAIL_API_KEY=

# Optional: target section for create/delete scripts (numeric section id from TestRail URL group_id)
TESTRAIL_SECTION_ID=

# Optional: JSON file for test case payloads
TESTRAIL_JSON_FILE=testcases.json
